          "name": "Bill",
          "fill": "#ffffff80",
          "content": "Bill",
          "lineHeight": 1.2857142857142858,
          "fontFamily": "PingFang SC",
          "fontSize": 14,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "R8kaH6",
          "x": 39,
          "y": 283,
          "name": "Open the e-wallet (e.g. Gcash, Paymaya), select “Payment Solutions” and enter Reference_No. to make the payment",
          "fill": "#171718ff",
          "textGrowth": "fixed-width",
          "width": 292,
          "content": "Open the e-wallet (e.g. Gcash, Paymaya), select “Payment Solutions” and enter Reference_No. to make the payment",
          "lineHeight": 1.5,
          "fontFamily": "PingFang SC",
          "fontSize": 12,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "zc7VU",
          "x": 39,
          "y": 350,
          "name": "Go to the bank or offline store, tell the staff that you want to pay bill, get the receipt from the clerk and complete the filling, after confirming the order, hand over your order and cash to the staff, and keep your receipt;",
          "fill": "#171718ff",
          "textGrowth": "fixed-width",
          "width": 292,
          "content": "Go to the bank or offline store, tell the staff that you want to pay  bill, get the receipt from the clerk and complete the filling, after confirming the order, hand over your order and cash to the staff, and keep your receipt;",
          "lineHeight": 1.5,
          "fontFamily": "PingFang SC",
          "fontSize": 12,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "mN0TA",
          "x": 37,
          "y": 491,
          "name": "The above is the repayment code of the order. If the fund is insufficient, the order will not be settled. Please note that if you want to defer the repayment, please return to the repayment page and click the “Defer” button to obtain the payment code for the deferment fee, and pay it . After you successfully repay, we will process your repayment and update the order status within 5-10 minutes. If you fail to repay, please try again.",
          "fill": "#666666ff",
          "textGrowth": "fixed-width",
          "width": 292,
          "content": "The above is the repayment code of the order. If the fund is insufficient, the order will not be settled. Please note that if you want to defer the repayment, please return to the repayment page and click the “Defer” button to obtain the payment code for the deferment fee, and pay it . After you successfully repay, we will process your repayment and update the order status within 5-10 minutes. If you fail to repay, please try again. ",
          "lineHeight": 1.5,
          "fontFamily": "PingFang SC",
          "fontSize": 12,
          "fontWeight": "normal"
        },
