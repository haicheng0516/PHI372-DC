        {
          "type": "text",
          "id": "Ep5tC",
          "x": 75,
          "y": 64,
          "name": "Repayment Instructions",
          "fill": "#ffffffff",
          "content": "Repayment Instructions",
          "lineHeight": 1.2,
          "textAlignVertical": "bottom",
          "fontFamily": "PingFang SC",
          "fontSize": 20,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "NKpXM",
          "x": 34,
          "y": 355,
          "name": "When making repayments, we kindly request you to first use the app to obtain the repayment link. In case the app is not accessible, you may also log in to our official website for repayment: [Official Website Link]. Please note that if the repayment link used is different from the one displayed on the app or official website, it will be considered a repayment failure.",
          "fill": "#666666ff",
          "textGrowth": "fixed-width",
          "width": 305,
          "content": "When making repayments, we kindly request you to first use the app to obtain the repayment link. In case the app is not accessible, you may also log in to our official website for repayment: [Official Website Link]. Please note that if the repayment link used is different from the one displayed on the app or official website, it will be considered a repayment failure.",
          "lineHeight": 1.4285714285714286,
          "fontFamily": "PingFang SC",
          "fontSize": 14,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "SS80R",
          "x": 34,
          "y": 555,
          "name": "If someone contacts you to split the total repayment amount into multiple payments, or sends you a repayment link that does not match what is displayed on the app or official website, please contact customer service for assistance.After verifying the situation, we will waive the service fee for you.",
          "fill": "#666666ff",
          "textGrowth": "fixed-width",
          "width": 305,
          "content": "If someone contacts you to split the total repayment amount into multiple payments, or sends you a repayment link that does not match what is displayed on the app or official website, please contact customer service for assistance.After verifying the situation, we will waive the service fee for you.",
          "lineHeight": 1.4285714285714286,
          "fontFamily": "PingFang SC",
          "fontSize": 14,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "sFFIe",
          "x": 34,
          "y": 715,
          "name": "If you encounter any suspicious situations during the repayment process, please contact customer service via email first. We will promptly assist you to resolve any issues.",
          "fill": "#666666ff",
          "textGrowth": "fixed-width",
          "width": 305,
          "content": "If you encounter any suspicious situations during the repayment process, please contact customer service via email first. We will promptly assist you to resolve any issues.",
          "lineHeight": 1.4285714285714286,
          "fontFamily": "PingFang SC",
          "fontSize": 14,
          "fontWeight": "normal"
        },
